# ───────────────────────────────────────────────────────────────────────────
# OpsFlow / TaskOs — environment configuration
#
# Copy this file to `.env` and fill in the values for your deployment:
#     cp .env.example .env
#     $EDITOR .env
#
# `.env` is gitignored. Required variables are marked [REQUIRED]; others
# are optional with sensible defaults.
# ───────────────────────────────────────────────────────────────────────────

# ───────────── DATABASES ─────────────

# [REQUIRED] Where OpsFlow OWNS and WRITES its data — the `taskos` schema
# (tasks, alerts, sessions, rules, escalations, history). Must include
# `?schema=taskos` so Prisma writes into that schema.
#
# Single-DB mode (taskos lives in the labstack DB):
#     DATABASE_URL=postgresql://USER:PASS@host:5432/labstack?schema=taskos
#
# Split-DB mode (dedicated OpsFlow Postgres):
#     DATABASE_URL=postgresql://opsflow:secret@opsflow-db:5432/opsflow?schema=taskos
#
# From inside Docker, `localhost` doesn't reach the host machine — use
# `host.docker.internal` (compose adds host-gateway mapping for Linux).
DATABASE_URL=postgresql://USER:PASSWORD@host.docker.internal:5432/labstack?schema=taskos

# [OPTIONAL] Where the source-of-truth data lives — orders, appointments,
# users, stores, labs. OpsFlow ONLY reads from this DB; it never writes.
#
# • Leave blank for single-DB mode — falls back to DATABASE_URL.
# • Set when the source DB is a different Postgres instance from taskos.
# • Most managed Postgres providers (RDS/Supabase/Aiven) need
#   `?sslmode=require` appended.
#
# Examples:
#     SOURCE_DATABASE_URL=postgresql://reader:secret@labstack-prod:5432/labstack
#     SOURCE_DATABASE_URL=postgresql://USER:PASS@db.example.com:5432/labstack?sslmode=require
#
# The user on the source DB only needs SELECT — OpsFlow never writes.
SOURCE_DATABASE_URL=

# [OPTIONAL] Set to `true` to skip `prisma db push` at container boot.
# Default false. Set true when pointing at an existing labstack DB whose
# `taskos` schema is already in place and you don't want Prisma to try
# reconciling drift.
SKIP_PRISMA_PUSH=false

# ───────────── APP ─────────────

# [OPTIONAL] Port the Next.js server listens on (also mapped to host).
APP_PORT=3000

# [OPTIONAL] Public URL for link generation (emails, webhooks, etc.).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [OPTIONAL] Server timezone. All SLA deadlines + roster math are
# computed in this zone. Default Asia/Kolkata (LabStack's operating zone).
TIMEZONE=Asia/Kolkata

# ───────────── AUTH ─────────────

# [REQUIRED] Secret used to sign JWT session tokens. MUST be a strong
# random string of ≥32 characters. The app refuses to start in
# production with a missing, short, or placeholder value.
#
# Generate one with:
#     openssl rand -hex 32
JWT_SECRET=please-change-me-in-production

# [OPTIONAL] Token lifetime. Examples: `8h`, `1d`, `30m`. Default `8h`.
JWT_EXPIRES_IN=8h

# ───────────── ADMIN SEED ─────────────
# These set the initial OPS_HEAD admin user — applied ONCE on first boot.
# Subsequent boots are idempotent: the seed will not overwrite an existing
# user's password. To rotate the admin password later, see DOCKER.md
# (`Resetting the admin password`).

ADMIN_EMAIL=admin@opsflow.local
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# ───────────── ENGINE / POLLER ─────────────

# [OPTIONAL] How often the engine polls the source DB for new orders to
# turn into tasks. In milliseconds. Default 300000 (5 minutes).
POLLING_INTERVAL_MS=300000

# ───────────── NOTIFICATIONS (optional) ─────────────
# Wire these up if you want WhatsApp alerts on SLA breaches / escalations.
# Leave blank to disable.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# ───────────── DEV OVERLAY ─────────────
# Used ONLY when running:
#     docker compose -f docker-compose.yml -f docker-compose.dev.yml up
# These spin up an extra Postgres container so you can run the whole
# stack from scratch without an existing labstack DB. The dev overlay
# overrides DATABASE_URL to point at this container.

POSTGRES_DB=opsflow
POSTGRES_USER=opsflow
POSTGRES_PASSWORD=opsflow_dev_password
DB_PORT=5433
