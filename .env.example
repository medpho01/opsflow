# Where OpsFlow stores its own data (taskos schema): tasks, alerts,
# users, sessions, task_rules, escalations, etc. OpsFlow OWNS this DB and
# writes to it.
DATABASE_URL=postgresql://USER:PASSWORD@host.docker.internal:5432/labstack?schema=taskos

# Where the source data (orders, appointments, users, stores, labs)
# lives. OpsFlow ONLY reads from this DB. If unset, falls back to
# DATABASE_URL — single-DB deployments don't need to set this.
# Set it when the source-of-truth lives on a different Postgres instance.
#
#   Examples:
#     SOURCE_DATABASE_URL=postgresql://reader:secret@labstack-prod:5432/labstack
#     SOURCE_DATABASE_URL=postgresql://USER:PASS@db.example.com:5432/labstack?sslmode=require
#
# When DATABASE_URL and SOURCE_DATABASE_URL point at the same Postgres
# instance, you can keep DATABASE_URL with `?schema=taskos` and leave
# SOURCE_DATABASE_URL unset; OpsFlow will reuse the same connection.
SOURCE_DATABASE_URL=

APP_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=please-change-me-in-production
JWT_EXPIRES_IN=8h

ADMIN_EMAIL=admin@opsflow.local
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

POLLING_INTERVAL_MS=300000

TIMEZONE=Asia/Kolkata

WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

POSTGRES_DB=opsflow
POSTGRES_USER=opsflow
POSTGRES_PASSWORD=opsflow_dev_password
DB_PORT=5433
