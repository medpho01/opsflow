# Copy to `.env` and adjust as needed. Defaults work for local Docker.
#
# Postgres ────────────────────────────────────────────────────────────
POSTGRES_DB=opsflow
POSTGRES_USER=opsflow
POSTGRES_PASSWORD=opsflow_dev_password
# Host-side port. 5433 (not 5432) so we don't collide with a local
# Postgres install on the dev machine. Inside the network containers
# always reach the DB at db:5432.
DB_PORT=5433

# Application ─────────────────────────────────────────────────────────
APP_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth — CHANGE BEFORE DEPLOYING. Used to sign session JWTs; rotating
# this invalidates every existing session.
JWT_SECRET=please-change-me-in-production
JWT_EXPIRES_IN=8h

# Initial admin user — created on first boot, idempotent thereafter.
# Change ADMIN_PASSWORD before exposing the app to anyone.
ADMIN_EMAIL=admin@opsflow.local
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Admin

# Polling engine ──────────────────────────────────────────────────────
# How often the legacy poller runs. 300000ms = 5min. Lower = more reactive,
# more DB load.
POLLING_INTERVAL_MS=300000

# Timezone — kept consistent across DB session, Node runtime, and the
# app's IST anchoring. Don't change unless you know what you're doing.
TIMEZONE=Asia/Kolkata

# Optional integrations (leave blank to disable) ──────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
