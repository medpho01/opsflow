{
  "name": "taskos-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && node node_modules/next/dist/bin/next dev",
    "build": "rm -rf .next && node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "db:seed": "node node_modules/.bin/tsx prisma/seed.ts",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:studio": "node node_modules/prisma/build/index.js studio",
    "db:generate": "node node_modules/prisma/build/index.js generate"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.0.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^4.16.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^4.16.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
